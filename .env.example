# Local Docker database
POSTGRES_USER=thunderstrux
POSTGRES_PASSWORD=thunderstrux
POSTGRES_DB=thunderstrux
DATABASE_URL=postgresql://thunderstrux:thunderstrux@db:5432/thunderstrux?schema=public

# Auth.js / NextAuth
# Generate a real value for local use, for example:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-non-empty-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Browser-facing app URL
# Use localhost for auth callbacks and Stripe redirects, not 0.0.0.0.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
# STRIPE_SECRET_KEY must belong to the Stripe platform account.
# Complete the Stripe Connect platform profile before Express account creation.
STRIPE_SECRET_KEY=

# Webhook secrets must come from the exact Stripe CLI listen process or Dashboard endpoint in use.
# Checkout webhook: /api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Connect webhook: /api/stripe/connect/webhook
STRIPE_CONNECT_WEBHOOK_SECRET=
