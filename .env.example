# Application environment.
#
# For Docker Compose, keep the db host as "db".
# For host-only Prisma debugging against the dev-exposed database port, use:
# DATABASE_URL=postgresql://thunderstrux:thunderstrux@localhost:5433/thunderstrux?schema=public
DATABASE_URL=postgresql://thunderstrux:thunderstrux@db:5432/thunderstrux?schema=public

# Auth.js / NextAuth
# Generate a real value for local use, for example:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-non-empty-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Browser-facing app URL
# Use localhost for auth callbacks and Stripe redirects, not 0.0.0.0.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional extra trusted origins for cookie-authenticated mutation APIs.
# Comma-separated absolute origins, for example:
# TRUSTED_APP_ORIGINS=https://admin.example.com,https://preview.example.com
TRUSTED_APP_ORIGINS=

# Rate limiting
# Keep disabled locally unless testing Redis-backed throttling.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REDIS_URL=redis://redis:6379
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_KEY_PREFIX=thunderstrux

# Stripe
# STRIPE_SECRET_KEY must belong to the Stripe platform account.
# Complete the Stripe Connect platform profile before Express account creation.
STRIPE_SECRET_KEY=

# Webhook secrets must come from the exact Stripe CLI listen process or Dashboard endpoint in use.
# Checkout webhook: /api/payments/webhook
STRIPE_WEBHOOK_SECRET=

# Connect webhook: /api/stripe/connect/webhook
STRIPE_CONNECT_WEBHOOK_SECRET=

# Email delivery
# Resend API key for ticket confirmation emails.
RESEND_API_KEY=

# Verified sender address, for example:
# Thunderstrux <tickets@example.com>
EMAIL_FROM=
