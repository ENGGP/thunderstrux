generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String               @id @default(cuid())
  email                   String               @unique
  password                String
  accountRole             AccountRole          @default(member)
  firstName               String?
  lastName                String?
  displayName             String?
  phone                   String?
  studentNumber           String?
  onboardingCompletedAt   DateTime?
  createdAt               DateTime             @default(now())
  organisationMemberships OrganisationMember[]
  ownedOrganisation       Organisation?        @relation("OrganisationAccount")
  orders                  Order[]
  reservations            TicketReservation[]

  @@index([accountRole])
}

model Organisation {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  accountUserId       String?              @unique
  stripeAccountId     String?
  stripeAccountStatus String?
  stripeChargesEnabled Boolean              @default(false)
  stripePayoutsEnabled Boolean              @default(false)
  stripeDetailsSubmitted Boolean            @default(false)
  createdAt           DateTime             @default(now())
  accountUser         User?                @relation("OrganisationAccount", fields: [accountUserId], references: [id], onDelete: SetNull)
  members             OrganisationMember[]
  events              Event[]
  orders              Order[]
  tickets             Ticket[]
  reservations        TicketReservation[]

  @@index([accountUserId])
  @@index([stripeAccountId])
}

model OrganisationMember {
  id             String           @id @default(cuid())
  userId         String
  organisationId String
  role           OrganisationRole
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@index([organisationId])
  @@index([userId])
}

model Event {
  id             String      @id @default(cuid())
  organisationId String
  title          String
  description    String
  startTime      DateTime
  endTime        DateTime
  location       String
  status         EventStatus @default(draft)
  createdAt      DateTime    @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  ticketTypes    TicketType[]
  tickets        Ticket[]
  orders         Order[]
  reservations   TicketReservation[]

  @@index([organisationId])
  @@index([organisationId, status])
  @@index([status, startTime, id], map: "Event_status_startTime_id_idx")
}

model TicketType {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  price     Int
  quantity  Int
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets   Ticket[]
  orders    Order[]
  reservations TicketReservation[]

  @@index([eventId])
}

model Order {
  id              String       @id @default(cuid())
  organisationId  String
  eventId         String
  ticketTypeId    String
  userId          String?
  status          OrderStatus  @default(pending)
  quantity        Int
  unitPrice       Int
  totalAmount     Int
  stripeSessionId String?      @unique
  createdAt       DateTime     @default(now())
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  requiresCompensationReview Boolean @default(false)
  fulfilmentFailedAt DateTime?
  fulfilmentFailureReason String?
  isManuallyRefunded Boolean @default(false)
  ticketEmailSentAt DateTime?
  ticketEmailLastError String?
  ticketEmailResentAt DateTime?
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Restrict)
  event           Event        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticketType      TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  tickets         Ticket[]
  reservation     TicketReservation?
  emailOutboxJobs EmailOutbox[]

  @@index([organisationId])
  @@index([eventId])
  @@index([eventId, status, createdAt, id], map: "Order_eventId_status_createdAt_id_idx")
  @@index([ticketTypeId])
  @@index([userId])
  @@index([userId, status, createdAt, id], map: "Order_userId_status_createdAt_id_idx")
  @@index([status, createdAt], map: "Order_status_createdAt_idx")
}

model Ticket {
  id             String       @id @default(cuid())
  orderId        String
  eventId        String
  ticketTypeId   String
  organisationId String
  createdAt      DateTime     @default(now())
  checkedInAt    DateTime?
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType     TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([eventId])
  @@index([eventId, createdAt, id])
  @@index([eventId, checkedInAt])
  @@index([ticketTypeId])
  @@index([organisationId])
}

model EmailOutbox {
  id                  String            @id @default(cuid())
  orderId             String
  mode                EmailOutboxMode
  status              EmailOutboxStatus @default(pending)
  attempts            Int               @default(0)
  nextAttemptAt       DateTime          @default(now())
  processingStartedAt DateTime?
  lastError           String?
  providerMessageId   String?
  deliveredToProviderAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  sentAt              DateTime?
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt, createdAt])
  @@index([status, processingStartedAt])
  @@index([orderId])
}

model TicketReservation {
  id             String            @id @default(cuid())
  orderId        String            @unique
  organisationId String
  eventId        String
  ticketTypeId   String
  userId         String?
  quantity       Int
  status         ReservationStatus @default(active)
  expiresAt      DateTime
  createdAt      DateTime          @default(now())
  confirmedAt    DateTime?
  releasedAt     DateTime?
  releaseReason  String?
  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  organisation   Organisation      @relation(fields: [organisationId], references: [id], onDelete: Restrict)
  event          Event             @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticketType     TicketType        @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketTypeId, status, expiresAt])
  @@index([status, expiresAt], map: "TicketReservation_status_expiresAt_idx")
  @@index([orderId])
  @@index([userId])
}

enum OrganisationRole {
  org_owner
  org_admin
  event_manager
  finance_manager
  content_manager
  member
}

enum AccountRole {
  member
  organisation
}

enum EventStatus {
  draft
  published
}

enum OrderStatus {
  pending
  paid
  failed
  expired
}

enum EmailOutboxMode {
  automatic
  manual
}

enum EmailOutboxStatus {
  pending
  processing
  sent
  failed
}

enum ReservationStatus {
  active
  confirmed
  released
  expired
}
